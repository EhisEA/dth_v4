    "version": "0.2.0",
    "configurations": [
        {
            "name": "dth",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "dth (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "dth prod",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prod.dart",
            // assumed fluttermode is debug
        },
        {
            "name": "dth dev",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            // assumed fluttermode is debug
        },
        {
            "name": "dth (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}


